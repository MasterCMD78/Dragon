{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd /app && pnpm --filter @workspace/website run build"
  },
  "deploy": {
    "startCommand": "cd /app && pnpm --filter @workspace/website run serve",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
